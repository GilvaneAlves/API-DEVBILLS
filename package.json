{
  "name": "api-devbils",
  "version": "1.0.0",
  "description": "API DevBils - Fastify + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "biome lint .",
    "format": "biome format . --write",
