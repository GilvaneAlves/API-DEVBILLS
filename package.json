    "mongodb": "^7.1.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@types/node": "^25.2.3",
    "cross-env": "^7.0.3",
    "prisma": "5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
